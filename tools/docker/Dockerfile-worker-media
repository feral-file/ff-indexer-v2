# Build stage
FROM golang:1.24-alpine3.23 AS builder

# Set working directory
WORKDIR /build

# Install build dependencies for CGO and libvips.
# vips 8.18+ lives in edge/community; edge/main must be listed too or apk mixes
# stable main with edge community and fails to resolve (e.g. python3 vs py3-imath).
RUN apk add --no-cache \
    build-base \
    musl-dev \
    pkgconfig \
    --repository=http://dl-cdn.alpinelinux.org/alpine/edge/main \
    --repository=http://dl-cdn.alpinelinux.org/alpine/edge/community \
    vips-dev~=8.18

# Copy resvg library and headers from pre-built image
COPY --from=feralfile/resvg-builder:v0.45.1 /usr/local/lib/libresvg.a /usr/local/lib/
COPY --from=feralfile/resvg-builder:v0.45.1 /usr/local/include/resvg.h /usr/local/include/

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the application with CGO enabled
ENV CGO_ENABLED=1
ENV CGO_LDFLAGS="-L/usr/local/lib"
ENV CGO_CFLAGS="-I/usr/local/include"
RUN go build -ldflags="-w -s" -o /build/bin/worker-media ./cmd/worker-media

# Runtime stage (pin to match golang:1.24-alpine3.23; avoid drift vs edge vips deps)
FROM alpine:3.23

# Install runtime dependencies
# - ca-certificates: for HTTPS
# - libgcc: required by statically linked Go binary with CGO
# - vips: libvips runtime library (8.18.0+ from edge; use edge/main + community like builder)
# - chromium: for headless browser SVG rendering via chromedp
# - chromium-chromedriver: driver for chromium automation
# - font-noto: fonts for proper text rendering in browser
RUN apk add --no-cache \
    ca-certificates \
    libgcc \
    --repository=http://dl-cdn.alpinelinux.org/alpine/edge/main \
    --repository=http://dl-cdn.alpinelinux.org/alpine/edge/community \
    vips~=8.18 \
    chromium \
    chromium-chromedriver \
    font-noto

# Set Chromium environment variables for headless operation
ENV CHROME_BIN=/usr/bin/chromium-browser \
    CHROME_PATH=/usr/lib/chromium/

# Create non-root user
RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser

WORKDIR /app

# Copy binary from builder
COPY --from=builder /build/bin/worker-media .

# Change ownership
RUN chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Run the application
CMD ["./worker-media", "-config", "config.yaml"]

